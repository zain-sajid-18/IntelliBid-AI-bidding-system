{
  "name": "intellibid-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "test:client": "npm run test --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:all": "concurrently \"npm run test:server\" \"npm run test:client\""
  },
  "dependencies": {
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}